  "publicApiSurface": [
    "spot <query>",
    "spot play [-a | -s] <query>",
    "spot search [-a | -r | -p] <query>",
    "spot now",
    "spot pause",
    "spot resume",
    "spot toggle",
    "spot next",
    "spot prev",
    "spot vol [0-100]",
    "spot shuffle [on|off]",
    "spot repeat [on|off]",
    "spot auth [--status]",
    "spot alias add <name> <query>",
    "spot alias rm <name>",
    "spot alias ls"
  ]
